# Database Configuration
# Note: Database config is loaded from ~/database_config.json (shared with chat-history-crawler)
# No need to configure DB settings here
DB_NAME_TO_USE=aliyunDB

# ===== DeepSeek AI Configuration (推荐 - 主要分析模型) =====
# 获取API密钥: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here
DEEPSEEK_MODEL_R1=deepseek-reasoner
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_TEMP_EVIDENCE=0.3
DEEPSEEK_TEMP_INFERENCE=0.7

# Zhipu AI Configuration (保留作为降级选项)
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4-plus

# ===== Redis (Phase 1) =====
# 本地开发: 使用Docker运行Redis
#   docker run -d -p 6379:6379 redis
# 生产环境: 使用阿里云Redis（配置Redis URL）
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# ===== AI Cache Configuration =====
AI_ENABLE_CACHE=true
AI_CACHE_TTL_DAYS=30

# ===== Cost Management (Phase 2, 4) =====
AI_DAILY_BUDGET=50.0
AI_MONTHLY_BUDGET=1500.0
AI_BUDGET_ALERT_THRESHOLD=0.8

# ===== Model Selection (Phase 2) =====
AI_CHAT_COUNT_LOW=10
AI_CHAT_COUNT_MEDIUM=20

# ===== Task Queue (Phase 3) =====
AI_TASK_QUEUE_MAX_CONCURRENT=5

# ===== Batch Analysis (Phase 6) =====
AI_BATCH_ENABLED=true
AI_BATCH_MAX_BUYERS=500

# ===== Alerting (Phase 6) =====
# 邮件通知配置（用于批量分析失败预警）
ALERT_EMAIL_FROM=your_email@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password
ALERT_EMAIL_TO=admin@company.com

# ===== API Configuration =====
API_HOST=0.0.0.0
API_PORT=8000
